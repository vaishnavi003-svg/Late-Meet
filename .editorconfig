root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,mjs,cjs,jsx,ts,tsx,json,jsonc,css,html,svg}]
indent_style = space
indent_size = 2

[.{prettierrc,prettierignore,gitignore}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf