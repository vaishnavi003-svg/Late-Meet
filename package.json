{
  "name": "late-meet",
  "version": "1.1.0",
  "description": "Privacy-first AI meeting copilot for Google Meet with real-time transcription and late-joiner summaries.",
  "main": "background.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "tsx --test src/audioProcessing.test.ts src/audioChunkQueue.test.ts src/participantDetection.test.ts src/meetingTabs.test.ts src/sessionStorage.test.ts src/dashboardCapture.test.ts src/popupCapture.test.ts src/speakerAttribution.test.ts src/utils/credentials.test.ts",
    "lint": "eslint . --ext .ts,.js",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shouri123/Late-Meet.git"
  },
  "keywords": [
    "chrome-extension",
    "google-meet",
    "ai",
    "meeting-copilot",
    "transcription",
    "privacy",
    "elevenlabs",
    "openai",
    "manifest-v3",
    "byok"
  ],
  "author": "Shouri",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shouri123/Late-Meet/issues"
  },
  "homepage": "https://github.com/shouri123/Late-Meet#readme",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "chrome-types": "^0.1.428",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "tsx": "^4.20.3",
    "typescript": "^5.3.3",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.45.0",
    "@openrouter/sdk": "^0.12.20"
  }
}
